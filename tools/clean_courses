#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="."
GET_FILES_DIR="~Get Your Files Here !"

echo "Starting cleanup from: $(pwd)"
echo

###############################################################################
# 1. Rename only top-level directories:
#    Remove opening "[ WebToolTip.com ]" / similar WebToolTip(s) prefix
#    and remove whitespace/separators before the real directory name.
###############################################################################

echo "Step 1: Removing WebToolTip prefix from top-level directories..."

find "$ROOT_DIR" -mindepth 1 -maxdepth 1 -type d -print0 |
while IFS= read -r -d '' dir; do
    parent="$(dirname "$dir")"
    base="$(basename "$dir")"

    # Handles examples like:
    #   [ WebToolTip.com ] Course Name
    #   [WebToolTip.com] Course Name
    #   [ WebToolTips.com ] Course Name
    #   [ WebToolTip.com ] - Course Name
    #   [ WebToolTip.com ]_Course Name
    newbase="$(printf '%s' "$base" | sed -E 's/^\[[[:space:]]*WebToolTips?\.com[[:space:]]*\][[:space:]_-]*//')"

    if [[ "$base" != "$newbase" ]]; then
        target="$parent/$newbase"

        if [[ -z "$newbase" ]]; then
            echo "SKIP: '$dir' would become an empty directory name."
        elif [[ -e "$target" ]]; then
            echo "SKIP: Cannot rename '$dir' to '$target' because target already exists."
        else
            echo "Rename directory:"
            echo "  FROM: $dir"
            echo "  TO:   $target"
            mv -- "$dir" "$target"
        fi
    fi
done

echo

###############################################################################
# 2. Recursively replace whitespace characters in all file and directory names
#    with underscores.
#
#    Deepest-first prevents path problems when renaming nested directories.
###############################################################################

echo "Step 2: Replacing whitespace in file and directory names with underscores..."

find "$ROOT_DIR" -depth -mindepth 1 -print0 |
while IFS= read -r -d '' path; do
    dir="$(dirname "$path")"
    base="$(basename "$path")"

    newbase="$(printf '%s' "$base" | sed -E 's/[[:space:]]+/_/g')"

    if [[ "$base" != "$newbase" ]]; then
        target="$dir/$newbase"

        if [[ -e "$target" ]]; then
            echo "SKIP: Cannot rename '$path' to '$target' because target already exists."
        else
            echo "Rename:"
            echo "  FROM: $path"
            echo "  TO:   $target"
            mv -- "$path" "$target"
        fi
    fi
done

echo

###############################################################################
# 3. Find folders named "~Get Your Files Here !".
#    After step 2, this folder name becomes "~Get_Your_Files_Here_!".
#
#    Move all contents up one level, then delete the folder if empty.
###############################################################################

echo "Step 3: Moving contents out of '~Get Your Files Here !' folders..."

NORMALIZED_GET_FILES_DIR="$(printf '%s' "$GET_FILES_DIR" | sed -E 's/[[:space:]]+/_/g')"

find "$ROOT_DIR" -type d -name "$NORMALIZED_GET_FILES_DIR" -print0 |
while IFS= read -r -d '' getdir; do
    parent="$(dirname "$getdir")"

    echo "Processing: $getdir"

    shopt -s dotglob nullglob
    items=( "$getdir"/* )

    if (( ${#items[@]} > 0 )); then
        for item in "${items[@]}"; do
            itembase="$(basename "$item")"
            target="$parent/$itembase"

            if [[ -e "$target" ]]; then
                echo "SKIP: Cannot move '$item' to '$target' because target already exists."
            else
                echo "Move:"
                echo "  FROM: $item"
                echo "  TO:   $target"
                mv -- "$item" "$target"
            fi
        done
    fi

    shopt -u dotglob nullglob

    if [[ -z "$(find "$getdir" -mindepth 1 -print -quit)" ]]; then
        echo "Deleting empty folder: $getdir"
        rmdir -- "$getdir"
    else
        echo "NOT EMPTY, keeping folder: $getdir"
    fi
done

echo

###############################################################################
# 4. Delete Bonus Resources files.
#
#    Includes original and likely normalized names.
###############################################################################

echo "Step 4: Deleting Bonus Resources files..."

find "$ROOT_DIR" -type f \( \
    -name "Bonus Resources.text" -o \
    -name "Bonus Resources.txt" -o \
    -name "Bonus_Resources.text" -o \
    -name "Bonus_Resources.txt" \
\) -print0 |
while IFS= read -r -d '' file; do
    echo "Deleting: $file"
    rm -- "$file"
done

echo
echo "Cleanup complete."
